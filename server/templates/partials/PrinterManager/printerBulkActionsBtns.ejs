<div class="text-center mt-1">
    <div class="btn-group">
        <button type="button" class="btn bg-colour-2 dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <i class="fas fa-crosshairs"></i> Массовые команды
        </button>
        <div class="dropdown-menu">
            <button
                    title="Connect multiple Printers at once."
                    id="bulkConnectBtn"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-link"></i> Подключить
            </button>
            <button
                    title="Diconnect multiple Printers at once."
                    id="bulkDisconnectBtn"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-unlink"></i> Отключить
            </button>
            <button
                    title="Power On/Off multiple Printers at once."
                    id="bulkPowerBtn"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-power-off"></i> Питание
            </button>

            <button
                    title="Send heating commands to multiple printers at once."
                    id="bulkPreHeat"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-temperature-high"></i> Предварительный нагрев
            </button>
            <button
                    title="Control multiple printers at once."
                    id="bulkControl"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-gamepad"></i> Управление
            </button>
            <button
                    title="Send gcode commands to multiple printers at once."
                    id="bulkGcodeCommands"
                    type="button"
                    class="dropdown-item"
                    href="#"
                    aria-expanded="false"
                    data-toggle="modal" data-target="#printerSelectModal"
            >
                <i class="fas fa-code"></i> Gcode
            </button>
        </div>
    </div>
</div>
