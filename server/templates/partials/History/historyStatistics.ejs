
<div class="row">
  <div class="col-lg-12 text-center text-light">
    <div class="row">
      <div class="col-lg-2">

      </div>
      <div class="col-lg-3">
        <b class="mt-1">Печати</b>
        <div class="row">
          <div class="col-lg-6">
            <b><i class="fas fa-clock"></i> Наибольшее время печати</b> <br />
            <%= helpers.generateTime(printStatistics.longestPrintTime) %><br />
            <b><i class="fas fa-clock"></i> Наименьшее время печати</b> <br />
            <%= helpers.generateTime(printStatistics.shortestPrintTime) %> <br />
          </div>
          <div class="col-lg-6">
            <b><i class="fas fa-clock"></i> Среднее время печати <br /></b><%=
            helpers.generateTime(printStatistics.averagePrintTime) %><br />
            <b><i class="fas fa-star"></i> Чаще всего печатаемый файл <br /></b><%=
            printStatistics.mostPrintedFile %><br />
          </div>
        </div>
      </div>
      <div class="col-lg-1">
        <b class="mt-1">Принтеры</b>
        <div class="row">
          <div class="col-lg-12">
            <b><i class="fas fa-star"></i> Наибольшее кол-во</b> <br />
            <%= printStatistics.printerMost %><br />
            <b><i class="fas fa-star-half-alt"></i> Наименьшее кол-во</b> <br />
            <%= printStatistics.printerLoad %> <br />
          </div>

        </div>
      </div>
      <div class="col-lg-3">
        <b class="mt-1">Филамент</b>
        <div class="row">
          <div class="col-lg-6">
            <b><i class="fas fa-weight"></i> Общий расход филамента</b> <br />
            <%= printStatistics.totalFilamentUsage %><br />
            <b><i class="fas fa-weight"></i> Средний расход филамента</b> <br />
            <%= printStatistics.averageFilamentUsage %> <br />
          </div>
          <div class="col-lg-6">
            <b><i class="fas fa-weight"></i> Наибольший расход филамента <br /></b><%=
            printStatistics.highestFilamentUsage %><br />
            <b><i class="fas fa-weight"></i> Наименьший расход филамента <br /></b><%=
            printStatistics.lowestFilamentUsage %><br />

          </div>
        </div>
      </div>
      <div class="col-lg-3">
        <b class="mt-1">Стоимость</b>
        <div class="row">
          <div class="col-lg-6">
            <b><i class="fas fa-tag"></i>  Общая стоимость катушки</b> <br />
            <%= printStatistics.totalSpoolCost %> <br />
            <b><i class="fas fa-tag"></i>  Наибольшая стоимость катушки</b> <br />
            <%= printStatistics.highestSpoolCost %><br />

          </div>
          <div class="col-lg-6">
            <b><i class="fas fa-tag"></i>  Общая стоимость принтера</b> <br />
            <%= printStatistics.totalPrinterCost %> <br />
            <b><i class="fas fa-tag"></i>  Наибольшая стоимость принтера</b> <br />
            <%= printStatistics.highestPrinterCost %><br />

          </div>
        </div>
      </div>
    </div>
  </div>
</div>
