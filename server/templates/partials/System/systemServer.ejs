<% const base = '../' %>
<% const modal = base + '/octofarm-modal.ejs' %>

<% const instructionsURL = "https://docs.octofarm.net/installation/setup-service.html" %>
<% const updateURL = "https://docs.octofarm.net/getting-started/octofarm-updating.html" %>
<% const installationURL = "https://docs.octofarm.net/installation/" %>

<% let updateDisabled = "disabled"; %>

<% if( serviceInformation?.update?.update_available ) { updateDisabled = "" } %>

<% if(systemInformation?.warnings?.status){ %>
    <div class="alert alert-<%= systemInformation.warnings.status; %>" role="alert">
        <%= systemInformation.warnings?.message; %>
    </div>
<% } %>
<% if(!serviceInformation?.isPm2 && !serviceInformation?.isNodemon){ %>
    <div class="alert alert-warning text-dark" role="alert">
        Ваша система не работает с PM2! Некоторые команды ниже могут не работать... Пожалуйста,
        настройте систему правильно, как указано здесь: <a
                rel=”noopener” href='<%= instructionsURL %>' target='_blank'>Нажмите здесь</a>
    </div>
<% } %>
<% if(serviceInformation?.isNodemon){ %>
    <div class="alert alert-success" role="alert">
        <i class="fas fa-heart text-danger"></i> Привет, замечательный разработчик! Спасибо, что помогаете делать OctoFarm лучше!
    </div>
<% } %>
<% let systemButtonsDisabled = false; %>
<% if(serviceInformation?.isDockerContainer){ %>
    <div class="alert alert-warning text-dark" role="alert">
        Функция “Обновить OctoFarm” отключена, так как
        Docker имеет свой собственный механизм обновления.
        Пожалуйста, проверьте <a
                rel=”noopener” href=”<%= updateURL %>”>Инструкции по
            установке</a> для получения дополнительной информации об обновлении
        вашего docker-контейнера.
    </div>
    <% systemButtonsDisabled = true; %>
<% } %>
<% if(serviceInformation?.isNodemon && !serviceInformation?.isPm2){ %>
    <div class="alert alert-warning text-dark" role="alert">
        Функция “Обновить OctoFarm” отключена, так как не удалось
        обнаружить использование менеджера процессов pm2.
        Пожалуйста, переустановите OctoFarm, следуя <a rel=”noopener” target=”_blank” href=”<%= instructionsURL %>”>Инструкциям по
            установке</a>.
    </div>
    <% systemButtonsDisabled = true; %>
<% } %>
<% if(!areWeGitRepo && !serviceInformation?.isDockerContainer){ %>
    <div class="alert alert-warning text-dark" role="alert">
        Функция “Обновить OctoFarm” отключена, так как не удалось
        обнаружить git-репозиторий.
        Пожалуйста, проверьте <a rel=”noopener” target=”_blank” href=”<%= instructionsURL %>”>Инструкции по
            установке</a> для получения дополнительной информации о
        настройке.
    </div>
    <% systemButtonsDisabled = true; %>
<% } %>
<div class="row">
    <div class="col-12">
        <button title="Выполняет перезапуск службы OctoFarm"
                id="restartOctoFarmBtn" type="button"
                class="btn btn-danger mr-3 btn-lg">
            <i class="fas fa-sync"></i> Перезапуск
        </button>
        <button title="Проверяет наличие последних обновлений OctoFarm"
                id="checkUpdatesForOctoFarmBtn" type="button"
                class="btn btn-info ml-3 float-right btn-lg">
            <i class="fab fa-github"></i> Проверить обновления
        </button>
        <button title="Выполняет команду обновления OctoFarm до последней версии"
                id="updateOctoFarmBtn" type="button"
                class="btn btn-success ml-3 float-right btn-lg"
                <% updateDisabled %>>
            <i class="fas fa-thumbs-up"></i> Обновить OctoFarm
        </button>
    </div>
</div>
<hr>
<div class="row">
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a class="nav-link active"
               id="client-settings-list" data-toggle="list" href="#client-settings"
               role="tab" aria-controls="system"><i class="fas fa-desktop"></i> Общие</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-settings-list" data-toggle="list" href="#server-settings"
               role="tab" aria-controls="panelview"><i class="fas fa-cogs"></i>
                Система</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-timeout-list" data-toggle="list" href="#server-timeout"
               role="tab" aria-controls="listview"><i class="fas fa-stopwatch"></i>
                Таймауты</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-timeout-list" data-toggle="list" href="#server-views"
               role="tab" aria-controls="listview"><i class="fas fa-eye"></i>
                Виды мониторинга</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-history-list" data-toggle="list" href="#server-history"
               role="tab" aria-controls="listview"><i class="fas fa-history"></i>
                История</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-filament-list" data-toggle="list" href="#server-filament"
               role="tab" aria-controls="listview"><i
                        class="fas fa-toilet-paper"></i> Менеджер филамента</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-influx-list" data-toggle="list" href="#server-influx"
               role="tab" aria-controls="listview"><i class="fas fa-database"></i>
                Экспорт InfluxDB</a>
        </li>
        <li class="nav-item">
            <a class="nav-link"
               id="server-camera-list" data-toggle="list" href="#server-camera"
               role="tab" aria-controls="listview"><i class="fa-solid fa-camera"></i>
                Камеры</a>
        </li>
    </ul>
    <div class="col-12">
        <div class="tab-content" id="nav-tabContent">
            <div class="tab-pane fade show active" id="client-settings"
                 role="tabpanel" aria-labelledby="client-settings-list">
                <div class="row">
                    <div class="col-12 col-md-4">
                        <p class="font-weight-bold">Изменить фон</p>
                        <p>Нажмите кнопку ниже, чтобы загрузить фоновое
                            изображение.</p>
                        <small>ПРИМЕЧАНИЕ: Возможно, вам потребуется обновить кеш браузера,
                            если изменения не применились сразу.</small>
                        <form action="/settings/backgroundUpload"
                              enctype="multipart/form-data" method="POST">
                            <input class="btn bg-secondary" type="file"
                                   name="myFile"
                                   accept="image/jpeg,image/png,image/jpg"/>
                            <input id="backgroundSubmit" class="btn btn-primary"
                                   type="submit" value="Загрузить"
                                   accept="image/jpeg,image/png">
                        </form>
                        <p> Поддерживает <code>PNG, JPG</code></p>
                    </div>
                    <div class="col-12 col-md-4">
                        <img width="100%" src="images/bg.jpg">
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="server-settings"
                 role="tabpanel" aria-labelledby="server-settings-list">
                <p class="font-weight-bold">Порт сервера</p>
                <p>Порт, на котором OctoFarm будет принимать соединения для
                    встроенного клиента. Используйте файл .env в папке OctoFarm для изменения...</p>
                <p><b>По умолчанию</b>: 4000</p>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text">Порт (отключено):</span>
                    </div>
                    <input id="serverPortNo" type="number" class="form-control"
                           placeholder="6" aria-label="Refresh Rate"
                           disabled
                           value="4000" step="1">

                </div>
                <small class="form-text text-muted">Требуется перезапуск
                    сервера</small>
                <hr>
                <div class="row">
                    <div class="col-12">
                        <p class="font-weight-bold">Вход и регистрация</p>
                        <p>Измените требования входа/регистрации OctoFarm. Оба параметра
                            по умолчанию включены.</p>
                    </div>

                    <div class="col-md-12 col-lg-6">
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="requireLogin" required <%= (serverSettings.server.loginRequired) ? "checked" : "" %>
                                >
                                <label class="custom-control-label"
                                       for="requireLogin">Требовать вход</label>
                                <div class="valid-feedback">Вход включён</div>
                                <div class="invalid-feedback">Вход отключён</div>
                            </div>
                        </form>
                    </div>
                    <div class="col-md-12 col-lg-6">
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="requireRegistration" required <%= (serverSettings.server.registration) ? "checked" : "" %>
                                >
                                <label class="custom-control-label"
                                       for="requireRegistration">Регистрация</label>
                                <div class="valid-feedback">Регистрация
                                    включена
                                </div>
                                <div class="invalid-feedback">Регистрация
                                    отключена
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="server-timeout" role="tabpanel"
                 aria-labelledby="server-timeout">
                <small class="form-text text-muted">Не требуется перезапуск
                    сервера</small>
                <hr>
                <div class="row">
                    <div class="col-md-12 col-lg-6">
                        <p class="font-weight-bold">Повтор Websocket</p>
                        <p>Интервал, с которым OctoFarm будет повторно опрашивать websocket
                            при обнаружении потери соединения во время работы. Опрос будет
                            повторяться с этой частотой до восстановления соединения.</p>

                        <p><b>Мин</b>: 5 секунд (по умолчанию), <b>Макс:</b> 30 секунд
                        </p>
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text">Повтор Websocket:</span>
                            </div>
                            <input id="webSocketRetry" type="number"
                                   class="form-control" placeholder="6"
                                   aria-label="Refresh Rate"
                                   value="<%= serverSettings.timeout.webSocketRetry/1000 %>" min="5" max="30" step="0.5">
                            <div class="input-group-append">
                                <span class="input-group-text">Секунд</span>
                            </div>

                        </div>
                        <small id="emailHelp" class="form-text text-muted">Требуется
                            перезапуск сервера</small>
                        <hr>
                    </div>
                    <div class="col-md-6 col-lg-6">
                        <p class="font-weight-bold">Повтор API</p>
                        <p>Интервал, с которым OctoFarm будет пытаться подключиться
                            к OctoPrint. Применимо в основном, если ваш
                            принтер был офлайн при добавлении на ферму.</p>
                        <p><b>Мин</b>: 30 секунд (по умолчанию), <b>Макс:</b> 60 секунд
                        </p>
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text">Повтор API:</span>
                            </div>
                            <input id="APIRetry" type="number" class="form-control"
                                   placeholder="6" aria-label="Refresh Rate"
                                   value="<%= serverSettings.timeout.apiRetry/1000 %>" min="30" max="60"
                                   step="0.5">
                            <div class="input-group-append">
                                <span class="input-group-text">Секунд</span>
                            </div>

                        </div>
                        <small id="emailHelp" class="form-text text-muted">Требуется
                            перезапуск сервера</small>
                        <hr>
                    </div>
                </div>


            </div>
            <div class="tab-pane fade" id="server-filament" role="tabpanel"
                 aria-labelledby="server-filament-list">
                <div id="filamentManagerSetup" class="row">
                    <div class="col-lg-2">
                        <h5>Проверять катушку?</h5>
                        <div class="alert alert-info small" role="alert">
                            OctoFarm покажет предупреждение при попытке начать печать без прикреплённой катушки.
                        </div>
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="checkFilament" required <%= (serverSettings.filament.filamentCheck) ? "checked" : "" %>>
                                <label class="custom-control-label"
                                       for="checkFilament">Проверка филамента</label>
                                <div class="valid-feedback">Проверять катушку
                                </div>
                                <div class="invalid-feedback">Игнорировать проверку катушки
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="col-lg-2">
                        <h5>Скрывать пустые катушки?</h5>
                        <div class="alert alert-info small" role="alert">
                            Любая катушка с количеством ниже 0 будет скрыта из меню выбора интерфейса.
                        </div>
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="hideEmpty" required <%= (serverSettings.filament.hideEmpty) ? "checked" : "" %>>
                                <label class="custom-control-label"
                                       for="hideEmpty">Скрыть пустые</label>
                                <div class="valid-feedback">Скрывать пустые катушки
                                </div>
                                <div class="invalid-feedback">Показывать пустые катушки
                                </div>
                            </div>
                        </form>
                    </div>
                        <div class="col-lg-2">
                            <h5>Списывать при успешном использовании?</h5>
                            <div class="alert alert-info small" role="alert">
                                При успешном завершении печати OctoFarm использует метаданные филамента OctoPrint и спишет соответствующее количество с текущей выбранной катушки.
                            </div>
                            <form class="was-validated">
                                <div class="custom-control custom-checkbox mb-3">
                                    <input type="checkbox" class="custom-control-input"%>
                                           id="downDateSuccess" required <%= (serverSettings?.filament?.downDateSuccess) ? "checked" : "" %>>
                                    <label class="custom-control-label"
                                           for="downDateSuccess">Списание при успехе</label>
                                    <div class="valid-feedback">Списывать использование
                                    </div>
                                    <div class="invalid-feedback">Игнорировать использование
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="col-lg-2">
                        <h5>Списывать при неудачной/отменённой печати?</h5>
                        <div class="alert alert-info small" role="alert">
                            При неудачном/отменённом завершении печати OctoFarm использует метаданные филамента OctoPrint и спишет соответствующее количество с текущей выбранной катушки.
                            <b>ПРИМЕЧАНИЕ: </b> Это приблизительный расчёт, он никогда не будет точным.
                        </div>
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="downDateFailed" required <%= (serverSettings?.filament?.downDateFailed) ? "checked" : "" %>>
                                <label class="custom-control-label"
                                       for="downDateFailed">Списание при неудаче/отмене</label>
                                <div class="valid-feedback">Списывать использование
                                </div>
                                <div class="invalid-feedback">Игнорировать использование
                                </div>
                            </div>
                        </form>
                    </div>
                        <div class="col-lg-2">
                            <h5>Разрешить одну катушку на нескольких принтерах?</h5>
                            <div class="alert alert-info small" role="alert">
                                Разрешить выбор одной катушки на нескольких принтерах. Полезно, если вы отслеживаете филамент только по типу -- можно прикрепить 1 катушку к нескольким принтерам для более точного расчёта граммов.
                            </div>
                            <% let multiSelectOff = "d-none"; %>
                            <% if(serverSettings?.filament?.allowMultiSelect) { %>
                                <% multiSelectOff = "" %>
                            <% }%>
                            <div class="alert alert-warning small text-dark <%= multiSelectOff %>" role="alert">
                                Отключение этой опции удалит все текущие назначения филамента.
                            </div>
                            <form class="was-validated">
                                <div class="custom-control custom-checkbox mb-3">
                                    <input type="checkbox" class="custom-control-input"
                                           id="allowMultiSelect" required <%= (serverSettings?.filament?.allowMultiSelect) ? "checked" : "" %>>
                                    <label class="custom-control-label"
                                           for="allowMultiSelect">Множественный выбор</label>
                                    <div class="valid-feedback">Множественный выбор
                                    </div>
                                    <div class="invalid-feedback">Одиночный выбор
                                    </div>
                                </div>
                            </form>
                        </div>
                </div>
            </div>
            <div class="tab-pane fade" id="server-views" role="tabpanel"
                 aria-labelledby="server-timeout">
                <div class="row">
                    <div class="col-12">
                        <div class="alert alert-warning text-dark text-dark" role="alert">
                            Ниже приведены опции для включения и отключения определённых видов мониторинга в пользовательском интерфейсе.
                            <hr>
                            <b>Панельный:</b> Это стандартный вид OctoFarm, где у каждого принтера своя карточка. Позволяет полностью контролировать и мониторить ферму.<br>
                            <b>Список:</b> Это табличный вид, где каждый принтер находится в строке таблицы. Позволяет полностью контролировать и мониторить статус фермы без слота камеры.<br>
                            <b>Камеры:</b> Этот вид похож на панельный, но с фокусом на камеры. Напоминает видеорегистратор для фермы с полным контролем.<br>
                            <b>Группы:</b> Этот вид организует принтеры по назначенным группам. Отлично подходит для группового управления печатью, но имеет ограниченный мониторинг. <br>
                            <b>Текущие операции:</b> Это упрощённый вид с базовой информацией о печати. Отлично подходит для большого экрана статуса или наблюдения за состоянием фермы. Нет управления и ограниченный статус.<br>
                            <b>Комбинированный:</b> Это табличный вид, объединяющий камеры, список и панельный виды. Позволяет полный мониторинг и контроль.<br>

                        </div>
                    </div>
                </div>
                 <div class="row">
                         <% const viewNames = [ "Панельный", "Список", "Камеры", "Группы", "Текущие операции", "Комбинированный" ] %>
                         <% Object.keys(serverSettings.monitoringViews.toJSON()).forEach((key, index) => { %>
                             <div class="col-md-4 col-lg-2">
                                 <form class="was-validated">
                                     <div class="custom-control custom-checkbox mb-3">
                                         <input type="checkbox" class="custom-control-input"
                                                id="monitoring-<%= key %>" required <%= serverSettings.monitoringViews[key] ? "checked" : "" %>
                                         >
                                         <label class="custom-control-label"
                                                for="monitoring-<%= key %>"><%= viewNames[index] %> вид</label>
                                         <div class="valid-feedback"><%= viewNames[index] %> вид включён</div>
                                         <div class="invalid-feedback"><%= viewNames[index] %> вид отключён</div>
                                     </div>
                                 </form>
                             </div>
                         <% }) %>
                 </div>
            </div>
            <div class="tab-pane fade" id="server-history" role="tabpanel"
                 aria-labelledby="server-history-list">
                <div class="alert alert-secondary" role="alert">
                    OctoFarm может сохранять снимки/миниатюры в
                    историю. Эти опции включены по умолчанию, так как перед сохранением
                    проверяется наличие URL миниатюры/камеры.
                </div>
                <div class="alert alert-warning text-dark text-dark" role="alert">
                    Если вы используете Docker, убедитесь, что смонтировали "/app/images",
                    иначе данные не сохранятся после перезагрузки/обновления.
                </div>
                <div id="filamentManagerSetup" class="row">
                    <div class="col-12 col-sm-12 col-md-6 col-lg-4 col-xl-4">
                        <h6>Захват таймлапса</h6>
                        <div class="alert alert-warning text-dark text-dark" role="alert">
                            Для работы таймлапс должен быть включён в OctoPrint,
                            а затем активирован ниже. Он не включён по
                            умолчанию и не реагирует на настройки OctoPrint.
                        </div>
                        <div class="alert alert-info" role="alert">
                            <h5>Обновите настройки экземпляров</h5>
                            Работает только с форматом ".mp4" для видео.
                            OctoPrint по умолчанию использует ".mpg". Вы можете изменить это в
                            "Расширенных настройках" вашего экземпляра OctoPrint в
                            "Веб-камера и таймлапс". Измените настройку на "libx264".
                            Вы также можете выбрать между триггерами Z или Время в выпадающих списках.
                            <button id="setupTimelapseOctoPrint" type="button"
                                    class="btn btn-outline-dark btn-block mt-1">
                                Настроить ферму!
                            </button>
                        </div>
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
                                <input type="checkbox" class="custom-control-input"
                                       id="timelapseOnComplete" required <%= (serverSettings.history.timelapse.onComplete) ? "checked" : "" %>>
                                <label class="custom-control-label"
                                       for="timelapseOnComplete">При
                                    завершении</label>
                                <div class="valid-feedback">Таймлапс при завершении
                                    будет загружен в OctoPrint
                                </div>
                                <div class="invalid-feedback">Таймлапс при завершении
                                    игнорируется
                                </div>
                            </div>
                        </form>
                        <form class="was-validated">
                            <div class="custom-control custom-checkbox mb-3">
