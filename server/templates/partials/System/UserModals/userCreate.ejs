<div class="row">
    <div id="userCreateMessage" class="col-12">

    </div>
    <div class="form-group col-12">
        <label for="createName">Имя</label>
        <input type="name" id="createName" name="name" class="form-control" placeholder="Введите имя"
        />
    </div>
    <div class="form-group col-12">
        <label for="createUserName">Имя пользователя</label>
        <input type="username" id="createUserName" name="username" class="form-control" placeholder="Введите имя пользователя"
        />
    </div>
    <div class="form-group mb-3 col-12">
        <label  for="createGroup">Группа</label>
        <select class="custom-select" id="createGroup">
            <option value="User">Пользователь</option>
            <option value="Administrator">Администратор</option>
        </select>
    </div>
    <div class="form-group col-12">
        <label for="createPassword">Пароль</label>
        <input type="password" id="createPassword" name="password" class="form-control" placeholder="Новый пароль" autocomplete="new-password"
        />
    </div><br>
    <div class="form-group col-12">
        <label for="createPassword2">Подтвердите пароль</label>
        <input type="password" id="createPassword2" name="password2" class="form-control" placeholder="Подтвердите пароль" autocomplete="new-password"
        />
    </div>
</div>