<!-- Orders Management Page -->
<div class="row">
    <div class="col-lg-12">
        <div class="card bg-dark mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-clipboard-list"></i> Order Management
                    <button id="btnCreateOrder" class="btn btn-success btn-sm float-right" data-toggle="modal" data-target="#createOrderModal">
                        <i class="fas fa-plus"></i> New Order
                    </button>
                </h5>
            </div>
            <div class="card-body">
                <!-- Status Filters -->
                <div class="btn-group mb-3" role="group" aria-label="Status filters">
                    <button type="button" class="btn btn-sm btn-outline-info order-filter active" data-status="">All</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary order-filter" data-status="queued">Queued</button>
                    <button type="button" class="btn btn-sm btn-outline-primary order-filter" data-status="calculated">Calculated</button>
                    <button type="button" class="btn btn-sm btn-outline-warning order-filter" data-status="scheduled">Scheduled</button>
                    <button type="button" class="btn btn-sm btn-outline-success order-filter" data-status="printing">Printing</button>
                    <button type="button" class="btn btn-sm btn-outline-light order-filter" data-status="done">Done</button>
                    <button type="button" class="btn btn-sm btn-outline-danger order-filter" data-status="canceled">Canceled</button>
                </div>
                <!-- Orders Table -->
                <div class="table-responsive">
                    <table class="table table-dark table-striped table-hover" id="ordersTable">
                        <thead>
                            <tr>
                                <th>Priority</th>
                                <th>Name</th>
                                <th>Total Parts</th>
                                <th>Material</th>
                                <th>Mode</th>
                                <th>Est. Time</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th style="min-width: 200px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="ordersTableBody">
                            <!-- Populated by client JS -->
                        </tbody>
                    </table>
                </div>
                <div id="ordersLoading" class="text-center">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p>Loading orders...</p>
                </div>
                <div id="ordersEmpty" class="text-center" style="display:none;">
                    <p class="text-muted">No orders found. Create a new order to get started.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Order Modal -->
<div class="modal fade" id="createOrderModal" tabindex="-1" role="dialog" aria-labelledby="createOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="createOrderModalLabel"><i class="fas fa-plus-circle"></i> Create New Order</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="createOrderForm" enctype="multipart/form-data">
                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label for="orderName">Order Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="orderName" name="name" required placeholder="Enter order name">
                        </div>
                        <div class="form-group col-md-4">
                            <label for="orderPriority">Priority (1=Highest)</label>
                            <select class="form-control" id="orderPriority" name="priority">
                                <option value="1">1 — Critical</option>
                                <option value="2">2 — High</option>
                                <option value="3" selected>3 — Normal</option>
                                <option value="4">4 — Low</option>
                                <option value="5">5 — Background</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="orderComment">Comment</label>
                        <textarea class="form-control" id="orderComment" name="comment" rows="2" placeholder="Operator notes..."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-3">
                            <label for="orderPartsPerFile">Parts in File <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="orderPartsPerFile" name="partsPerFile" value="1" min="1" required>
                            <small class="form-text text-muted">How many parts in one 3MF file</small>
                        </div>
                        <div class="form-group col-md-3">
                            <label for="orderFileCopies">File Copies <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="orderFileCopies" name="fileCopies" value="1" min="1" required>
                            <small class="form-text text-muted">How many times to print the file</small>
                        </div>
                        <div class="form-group col-md-3">
                            <label for="orderEstTime">Est. Print Time (sec)</label>
                            <input type="number" class="form-control" id="orderEstTime" name="estimatedPrintTime" value="0" min="0">
                            <small class="form-text text-muted">Time per 1 print run (from slicer)</small>
                        </div>
                        <div class="form-group col-md-3">
                            <label>Total Parts</label>
                            <input type="text" class="form-control" id="orderTotalParts" readonly disabled>
                            <small class="form-text text-muted">Parts in File × File Copies</small>
                        </div>
                    </div>
                    <hr class="border-secondary">
                    <h6><i class="fas fa-cog"></i> Requirements</h6>
                    <div class="form-row">
                        <div class="form-group col-md-3">
                            <label for="orderVolumeX">Volume X (mm)</label>
                            <input type="number" step="0.1" class="form-control" id="orderVolumeX" name="volumeX" value="0" min="0">
                        </div>
                        <div class="form-group col-md-3">
                            <label for="orderVolumeY">Volume Y (mm)</label>
                            <input type="number" step="0.1" class="form-control" id="orderVolumeY" name="volumeY" value="0" min="0">
                        </div>
                        <div class="form-group col-md-3">
                            <label for="orderVolumeZ">Volume Z (mm)</label>
                            <input type="number" step="0.1" class="form-control" id="orderVolumeZ" name="volumeZ" value="0" min="0">
                        </div>
                        <div class="form-group col-md-3">
                            <label for="orderMaterial">Material</label>
                            <select class="form-control" id="orderMaterial" name="material">
                                <option value="">Any</option>
                                <option value="PLA">PLA</option>
                                <option value="PETG">PETG</option>
                                <option value="ABS">ABS</option>
                                <option value="TPU">TPU</option>
                                <option value="Nylon">Nylon</option>
                                <option value="ASA">ASA</option>
                                <option value="PC">PC</option>
                            </select>
                        </div>
                    </div>
                    <hr class="border-secondary">
                    <h6><i class="fas fa-print"></i> Printer Assignment</h6>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="orderReferencePrinter">Reference Printer</label>
                            <select class="form-control" id="orderReferencePrinter" name="referencePrinter">
                                <option value="">— Select printer 3MF was sliced for —</option>
                            </select>
                            <small class="form-text text-muted">The printer this file was sliced for</small>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="orderOptMode">Optimization Mode</label>
                            <select class="form-control" id="orderOptMode" name="optimizationMode">
                                <option value="min_time">Minimize Time (Greedy)</option>
                                <option value="min_idle">Minimize Idle (Balanced)</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Compatible Printer Groups</label>
                        <div id="compatibleGroupsContainer" class="border border-secondary rounded p-2" style="max-height: 200px; overflow-y: auto;">
                            <p class="text-muted mb-0"><i class="fas fa-spinner fa-spin"></i> Loading groups...</p>
                        </div>
                        <small class="form-text text-muted">Select which printer groups can produce this order. Reference printer's group is auto-selected.</small>
                    </div>
                    <div class="form-group">
                        <label for="orderFile">3MF / G-code File</label>
                        <input type="file" class="form-control-file" id="orderFile" name="file" accept=".3mf,.gcode,.gco,.g">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="btnSubmitOrder"><i class="fas fa-save"></i> Create Order</button>
            </div>
        </div>
    </div>
</div>

<!-- Schedule Results Modal -->
<div class="modal fade" id="scheduleResultModal" tabindex="-1" role="dialog" aria-labelledby="scheduleResultModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="scheduleResultModalLabel"><i class="fas fa-calculator"></i> Schedule Calculation Result</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="scheduleResultInfo" class="mb-3">
                    <p>Total Batches: <strong id="schedTotalBatches">-</strong></p>
                    <p>Total Estimated Time: <strong id="schedTotalTime">-</strong></p>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-striped">
                        <thead>
                            <tr>
                                <th>Printer Group</th>
                                <th>Printers</th>
                                <th>Batches</th>
                                <th>Per Printer</th>
                                <th>Est. Time</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="scheduleResultBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning" id="btnAssignSchedule"><i class="fas fa-check-double"></i> Assign Schedule</button>
            </div>
        </div>
    </div>
</div>

<!-- Upload G-code Modal -->
<div class="modal fade" id="uploadGcodeModal" tabindex="-1" role="dialog" aria-labelledby="uploadGcodeModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="uploadGcodeModalLabel"><i class="fas fa-file-upload"></i> Upload G-code for Group</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p id="gcodeGroupLabel" class="text-info mb-3"></p>
                <form id="uploadGcodeForm" enctype="multipart/form-data">
                    <input type="hidden" id="gcodeOrderId" name="orderId">
                    <input type="hidden" id="gcodeAssignmentId" name="assignmentId">
                    <div class="form-group">
                        <label for="gcodeFile">G-code File</label>
                        <input type="file" class="form-control-file" id="gcodeFile" name="gcode" accept=".gcode,.gco,.g" required>
                        <small class="form-text text-muted">This G-code will be shared by all printers in the group.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="btnSubmitGcode"><i class="fas fa-upload"></i> Upload</button>
            </div>
        </div>
    </div>
</div>

<!-- Order Detail Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" role="dialog" aria-labelledby="orderDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="orderDetailModalLabel"><i class="fas fa-info-circle"></i> Order Details</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="orderDetailBody">
                <!-- Populated by JS -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="/assets/js/orders.runner.<%= clientVersion %>.min.js" type="module"></script>
