<% if(typeof printerCount != 'undefined' && printerCount > 0 ) {%>
  <div id="listView" class="row">
    <% if(clientSettings.views.currentOperations){%> <%-
    include('./partials/currentOperations.ejs') %>
    <% }%>
      <%- include('./partials/actionsBar.ejs') %>
    <div class="col-lg-12 table-responsive-sm table-responsive-md">
      <table class=" table table-dark text-center table-hover">
          <thead>
          <tr>
              <th class="sticky-table table-dark" scope="col">Имя</th>
              <th class="sticky-table table-dark" scope="col">Статус</th>
              <th class="sticky-table table-dark" scope="col">
                  Управление
              </th>
              <th class="sticky-table table-dark" scope="col">
                  Контроль
              </th>
              <th class="sticky-table table-dark" scope="col">
                  Принтер
              </th>
              <th class="sticky-table table-dark" scope="col">Текущий файл
              </th>
              <th class="sticky-table table-dark printerTimeElapsed" scope="col">
                  Время печати (прошло)
              </th>
              <th class="sticky-table table-dark printerTimeElapsed" scope="col">
                  Прогресс
              </th>
              <th class="sticky-table table-dark printerRemainingTime" scope="col">
            Оставшееся время печати
          </th>
          <th class="sticky-table table-dark" scope="col" style="max-width:200px;">
            Сопла
          </th>
          <th class="sticky-table table-dark" scope="col" style="max-width:170px;">Стол / Камера</th>
        </tr>
        </thead>
        <tbody id="printerArea">

        </tbody>
      </table>
    </div>
  </div>
  <script src="/assets/js/list-view.runner.<%= clientVersion %>.min.js" type="module"></script>
  <script src="/assets/js/bulk-action-commands.functions.<%= clientVersion %>.min.js" type="module"></script>
<% }else{ %>
  <%- include('./addPrinters.ejs') %>
<% } %>


