<% let base = './partials' %>
<% let card = base + '/octofarm-card.ejs' %>
<% let table = base + '/octofarm-table.ejs' %>
<% let modal = base + '/octofarm-modal.ejs' %>

<div class="row">
    <% if(clientSettings.filamentManager.currentOperations){%> <%-
    include('./partials/currentOperations.ejs') %>
    <% }%>
</div>
<div class="row">
    <div class="col-sm-12 col-md-4 col-lg-2">
        <%- include(card, {
            tile:{
                id:"filamentManager",i:"fa-toilet-paper",title:"Менеджер филамента",class:"col-lg-12",
                },
                bodyFile:'./Filament/filamentManager.panel.ejs'
            })
        %>
    </div>
    <div class="col-sm-12 col-md-8 col-lg-10">
        <%- include(card, {
            tile:{
                id:"filamentStatistics",i:"fa-chart-area",title:"Статистика филамента",class:"col-lg-12",
                },
                bodyFile:'./Filament/filamentStatistics.panel.ejs'
            })
        %>
    </div>
</div>
<div class="row">
<% if(typeof historyStats !== "undefined" && typeof historyStats.totalByDay[0] !== "undefined" && historyStats.totalByDay[0].data.length > 1) {%>
    <div class="col-lg-6">
        <%- include(card, {
        tile:{
        id:"spoolUsageOverTime",i:"fa-star-half-alt",title:"Расход по дням",class:"col-lg-12",
        },
        bodyFile:'./Filament/totalSpoolUsage.chart.ejs'
        })
        %>
    </div>
<% } %>
<% if(typeof historyStats !== "undefined" && typeof historyStats.usageOverTime[0] !== "undefined" && historyStats.usageOverTime[0].data.length > 1) {%>
    <div class="col-lg-6">
        <%- include(card, {
        tile:{
        id:"incrementalSpoolUsage",i:"fa-star-half-alt",title:"Инкрементальный расход по дням",class:"col-lg-12",
        },
        bodyFile:'./Filament/incrementalSpoolUsage.chart.ejs'
        })
        %>
    </div>
<% } %>
</div>
<div class="row">
    <%- include(table, {
        table:{
            id:"filamentOverviewTable", contentId:"filamentOverviewList", hide:false, headers: [
                { title:"", style:"" },
                { title:"Название катушки", style:"min-width:50px;" },
                { title:"Материал", style:"" },
                { title:"Производитель", style:"min-width:300px;" },
                { title:"Вес катушки", style:"min-width:200px;" },
                { title:"Остаток", style:"min-width:50px;" },
                { title:"Сдвиг сопла", style:"min-width:150px;" },
                { title:"Сдвиг стола", style:"min-width:150px;" },
                { title:"Назначенный принтер", style:"min-width:10px;" }
            ]
            },
            bodyFile:'./Filament/spool.table.ejs'
        })
    %>
</div>
<!-- Spool Modal -->
<div class="modal fade" id="profileManagerModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Менеджер профилей</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        <div id="profilesMessage"></div>
                        <form>
                            <div class="form-row">
                                <div class="form-group col-md-6">
                                    <label for="profilesManufactuer">Производитель</label>
                                    <input type="text" class="form-control" id="profilesManufactuer">
                                </div>
                                <div class="form-group col-md-6">
                                    <label for="profilesMaterial">Материал</label>
                                    <input autocomplete="off" list="huge_list" type="text" class="form-control" id="profilesMaterial">
                                    <datalist id="huge_list" class="bg-secondary">
                                    </datalist>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-md-6">
                                    <label for="profilesDensity">Плотность</label>
                                    <div class="input-group mb-3">
                                        <input id="profilesDensity" type="number" class="form-control" value="1.25" step="0.01" aria-label="profilesDansity" aria-describedby="basic-addon2">
                                        <div class="input-group-append">
                                            <span class="input-group-text" id="basic-addon2">g/cm3</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-6">
                                    <label for="profilesDiameter">Диаметр</label>
                                    <div class="input-group mb-3">
                                        <input id="profilesDiameter" type="number" class="form-control" value="1.75" step="0.01" aria-label="" aria-describedby="profilesDiameter">
                                        <div class="input-group-append">
                                            <span class="input-group-text" id="basic-addon2">mm</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button id="addProfilesBtn" type="submit" class="btn btn-success">Добавить</button>
                        </form>
                        <br>
                        <hr>
                        <br>
                    </div>
                    <div class="col-12 text-center">
                        <nav
                                id="listenerProfiles"
                                data-jplist-control="pagination"
                                data-group="profiles"
                                data-items-per-page="5"
                                data-current-page="0"
                                data-disabled-class="disabled"
                                data-selected-class="active"
                                data-name="pagination"
                                data-id="profiles-pagination">
                            <!-- first and previous buttons -->
                            <div class="btn-group pagination d-inline-flex" role="group" aria-label="Basic example">
                                <button type="button" class="btn btn-secondary" data-type="first">Первая</button>
                                <button type="button" class="btn btn-secondary" data-type="prev">Предыдущая</button>
                            </div>
                            <div class="btn-group pagination d-inline-flex" data-type="pages">
                                <button type="button" class="btn btn-secondary" data-type="page">{pageNumber}</button>
                            </div>
                            <div class="btn-group pagination d-inline-flex" role="group" aria-label="Basic example">
                                <button type="button" class="btn btn-secondary" data-type="next">Следующая</button>
                                <button type="button" class="btn btn-secondary" data-type="lase">Последняя</button>
                            </div>
                            <!-- items per page dropdown -->
                            <div class="input-group mt-1 d-inline-flex">
                                <div class="input-group-prepend">
                                    <label class="input-group-text" for="inputGroupSelect01">Элементов на странице: </label>
                                </div>
                                <select data-type="items-per-page" class="custom-select" id="inputGroupSelect01">
                                    <option value="5">5</option>
                                    <option value="10">10</option>
                                    <option value="15">15</option>
                                    <option value="20">20</option>
                                    <option value="0">Все</option>
                                </select>
                            </div>
                            <!-- information labels -->
                            <span data-type="info" class="badge badge-secondary ml-3 p-2">
                                    Стр. {pageNumber} из {pagesNumber}
                            </span>
                        </nav>
                    </div>
                    <div class="col-12">
                        <table class="table-hover table table-responsive-sm table-responsive-md">
                            <thead>
                            <tr>
                                <th scope="col" style="min-width: 250px">Производитель</th>
                                <th scope="col" style="min-width: 250px">Материал</th>
                                <th scope="col" style="max-width: 50px">Плотность</th>
                                <th scope="col" style="max-width: 50px">Диаметр</th>
                                <th scope="col" style="min-width: 250px"></th>
                            </tr>
                            </thead>
                            <tbody id="addProfilesTable" data-jplist-group="profiles">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>
<!-- Spool Modal -->
<div class="modal fade" id="spoolManagerModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Менеджер катушек</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="addSpoolModalBody">
                <div id="addSpoolsMessage"></div>
                <form>
                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label for="spoolsName">Название</label>
                            <input type="text" class="form-control" id="spoolsName">
                        </div>
                        <div class="form-group col-md-4">
                            <label for="spoolsProfile">Профиль</label>
                            <select id="spoolsProfile" class="form-control">
                            </select>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="spoolsPrice">Цена</label>
                            <input type="number" class="form-control" id="spoolsPrice" step="0.01">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-3">
                            <label for="spoolsWeight">Вес</label>
                            <div class="input-group mb-3">
                                <input id="spoolsWeight" type="number" class="form-control" value="1000" step="1" aria-label="" aria-describedby="profilesDiameter">
                                <div class="input-group-append">
                                    <span class="input-group-text" id="basic-addon2">g</span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label for="spoolsRemaining">Использовано</label>
                            <div class="input-group mb-3">
                                <input id="spoolsRemaining" type="number" class="form-control" value="0" step="1" aria-label="" aria-describedby="profilesDiameter">
                                <div class="input-group-append">
                                    <span class="input-group-text" id="basic-addon2">g</span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label for="spoolsTempOffset">Сдвиг температуры сопла</label>
                            <div class="input-group mb-3">
                                <input id="spoolsTempOffset" type="number" class="form-control" placeholder="Recipient's username" value="0" step="1" max="50" min="-50" aria-label="" aria-describedby="basic-addon2">
                                <div class="input-group-append">
                                    <span class="input-group-text" id="basic-addon2">°C</span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label for="spoolsBedOffset">Сдвиг температуры стола</label>
                            <div class="input-group mb-3">
                                <input id="spoolsBedOffset" type="number" class="form-control" placeholder="Recipient's username" value="0" step="1" max="50" min="-50" aria-label="" aria-describedby="basic-addon2">
                                <div class="input-group-append">
                                    <span class="input-group-text" id="basic-addon2">°C</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button id="addSpoolBtn" type="submit" class="btn btn-success">Добавить</button>
                </form>
                <br>
                <hr>
                <br>
                <div class="row">
                    <div class="col-lg-4">
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <label class="input-group-text" for="inputGroupSelect01">Сортировка: </label>
                            </div>
                            <select class="custom-select" id="inputGroupSelect01"
                                    data-jplist-control="select-sort"
                                    data-group="spools"
                                    data-name="default-sort"
                                    data-id="default-sort"
                            >
                                <option
                                        value="0"
                                        data-path="default">Сортировка по</option>
                                <option             value="1"
                                                    data-path=".name"
                                                    data-order="asc"
                                                    data-type="text">Название (&uarr;)</option>
                                <option             value="2"
                                                    data-path=".name"
                                                    data-order="desc"
                                                    data-type="text">Название (&darr;)</option>
                                <option             value="3"
                                                    data-path=".price"
                                                    data-order="asc"
                                                    data-type="number">Цена (&uarr;)</option>
                                <option             value="4"
                                                    data-path=".price"
                                                    data-order="desc"
                                                    data-type="number">Цена (&darr;)</option>
                                <option             value="5"
                                                    data-path=".grams"
                                                    data-order="asc"
                                                    data-type="number"
                                                    class="">Остаток (&uarr;)</option>
                                <option             value="6"
                                                    data-path=".grams"
                                                    data-order="desc"
                                                    data-type="number"
                                                    class="">Остаток (&darr;)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <label class="input-group-text" for="materialsList">Материал: </label>
                            </div>
                            <select class="custom-select" id="materialsList"
                                    data-jplist-control="select-filter"
                                    data-group="spools"
                                    data-name="materialName"
                                    data-path=".material"
                            >
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text" id="basic-addon1">Поиск катушек</span>
                            </div>
                            <input type="text" class="form-control" aria-label="Username" aria-describedby="basic-addon1"
                                   data-jplist-control="textbox-filter"
                                   data-group="spools"
                                   data-name="fileNameSearch"
                                   data-path=".name"
                                   type="text"
                                   value=""
                                   placeholder="Поиск...">
                        </div>
                    </div>
                    <div class="col-12">
                        <center>
                            <nav
                                    id="listenerSpools"
                                    data-jplist-control="pagination"
                                    data-group="spools"
                                    data-items-per-page="5"
                                    data-current-page="0"
                                    data-disabled-class="disabled"
                                    data-selected-class="active"
                                    data-name="pagination"
                                    data-id="spools-pagination">
                                <!-- first and previous buttons -->
                                <div class="btn-group pagination d-inline-flex" role="group" aria-label="Basic example">
                                    <button type="button" class="btn btn-secondary" data-type="first">Первая</button>
                                    <button type="button" class="btn btn-secondary" data-type="prev">Предыдущая</button>
                                </div>
                                <div class="btn-group pagination d-inline-flex" data-type="pages">
                                    <button type="button" class="btn btn-secondary" data-type="page">{pageNumber}</button>
                                </div>
                                <div class="btn-group pagination d-inline-flex" role="group" aria-label="Basic example">
                                    <button type="button" class="btn btn-secondary" data-type="next">Следующая</button>
                                    <button type="button" class="btn btn-secondary" data-type="lase">Последняя</button>
                                </div>
                                <!-- items per page dropdown -->
                                <div class="input-group mb-3 d-inline-flex w-25">
                                    <div class="input-group-prepend">
                                        <label class="input-group-text" for="inputGroupSelect01">Элементов на странице: </label>
                                    </div>
                                    <select data-type="items-per-page" class="custom-select" id="inputGroupSelect01">
                                        <option value="5">5</option>
                                        <option value="20">20</option>
                                        <option value="50">50</option>
                                        <option value="100">100</option>
                                        <option value="0"> Все </option>
                                    </select>
                                </div>
                                <br>
                                <!-- information labels -->
                                <span data-type="info" class="badge badge-secondary ml-3 p-2">
                                    Стр. {pageNumber} из {pagesNumber}
                              </span>
                            </nav>
                        </center>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <table class="table-hover table table-responsive-sm table-responsive-md col-lg-12">
                            <thead>
                            <tr>
                                <th scope="col">Общая цена</th>
                                <th scope="col">Общий вес (г)</th>
                                <th scope="col">Использовано (г)</th>
                                <th scope="col">Остаток (г)</th>
                                <th scope="col">Остаток (%)</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td id="totalPrice"></td>
                                <td id="totalWeight"></td>
                                <td id="totalUsed"></td>
                                <td id="totalRemaining"></td>
                                <td id="totalRemainingPercent"></td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <table class="table-hover table table-responsive-sm table-responsive-md col-lg-12">
                    <thead>
                    <tr>
                        <th scope="col" style="min-width: 250px;">Название</th>
                        <th scope="col" style="min-width: 200px">Профиль</th>
                        <th scope="col" style="max-width: 50px">Цена</th>
                        <th scope="col" style="max-width: 100px">Вес (г)</th>
                        <th scope="col" style="max-width: 100px">Использовано (г)</th>
                        <th scope="col" style="max-width: 50px">Сдвиг сопла (°C)</th>
                        <th scope="col" style="max-width: 50px">Сдвиг стола (°C)</th>
                        <th scope="col" style="min-width: 300px">Назначение принтера</th>
                        <th scope="col" style="min-width: 200px"></th>
                    </tr>
                    </thead>
                    <tbody id="addSpoolsTable" data-jplist-group="spools">

                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>
<!-- Materials Modal -->
<div class="modal fade" id="materialsListModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Список материалов</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-6">
                        <div class="alert alert-info" role="alert">
                            <p>Ниже приведён список предопределённых материалов OctoFarm. При создании катушки эти данные используются для автоматического обновления плотности.</p>

                            <p>Плотность используется в расчётах по всему интерфейсу OctoFarm, особенно в истории, для оценки расхода по длине, полученной от OctoPrint.</p>
                        </div>
                    </div>
                    <div class="col-6">

                        <div class="alert alert-success" role="alert">
                            <p>Постоянно вводите свои материалы? Хотите помочь дополнить этот список?</p>

                            <p>Пожалуйста, создайте P.R. в GitHub-репозитории OctoFarm для файла /client/pages/filament-manager.utils.js, массив "materialsList".</p>

                            <a target="_blank" href="https://github.com/OctoFarm/OctoFarm/edit/master/client/js/pages/filament-manager.utils.js#L8"> Нажмите, чтобы редактировать! </a>
                        </div>
                    </div>
                    <div class="col-12">
                        <table class="table-hover table table-responsive-sm table-responsive-md">
                            <thead>
                            <tr>
                                <th></th>
                                <th scope="col">Код</th>
                                <th scope="col">Материал</th>
                                <th scope="col">Сокращение</th>
                                <th scope="col">Плотность</th>
                            </tr>
                            </thead>
                            <tbody id="materialsListTable">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>
<script src="/assets/js/filament-manager.runner.<%= clientVersion %>.min.js" type="module"></script>
</div>
