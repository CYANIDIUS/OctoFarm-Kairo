<% if(typeof history.length != 'undefined' && history.length > 0 ) {%>
<div class="row">
  <% if(clientSettings.history.currentOperations){%> <%-
  include('./partials/currentOperations.ejs') %>
  <% }%>
</div>
<div class="row">
  <div class="col-md-6 col-lg-3">
    <div class="bg-dark rounded p-2 row">
      <div class="col-md-4 col-lg-4">
        <h4 class="text-info">Общее время печати</h4>
        <h3 id="totalSparkLast" class="text-info">#</h3>

      </div>
      <div id="totalSpark" class="col-md-8 col-lg-8 text-right"></div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="bg-dark rounded p-2 row">
      <div class="col-md-4 col-lg-3">
        <h4 class="text-success">Процент успеха</h4>
        <h3 id="successSparkLast" class="text-success">#</h3>

      </div>
      <div id="successSpark" class="col-md-8 col-lg-9 text-right"></div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="bg-dark rounded p-2 row">
      <div class="col-md-4 col-lg-3">
        <h4 class="text-warning">Процент отмен</h4>
        <h3 id="cancelledSparkLast" class="text-warning">#</h3>

      </div>
      <div id="cancelledSpark" class="col-md-8 col-lg-9"></div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="bg-dark rounded p-2 row">
      <div class="col-md-4 col-lg-2">
        <h4 class="text-danger">Процент ошибок</h4>
        <h3 id="failedSparkLast" class="text-danger">#</h3>

      </div>
      <div id="failedSpark" class="col-md-8 col-lg-10 text-right"></div>
    </div>
  </div>
</div>

<div class="row">
  <div id="dashboardInfo" class="col-sm-12 col-md-6 col-lg-2 col-xl-2 mb-2 mb-2">
    <div class="card text-white bg-dark h-100">
      <div class="card-header dashHeader p-0">
        <button
                type="button"
                class="btn btn-secondary d-block ml-1 mr-1 p-1"
                href="#"
                aria-expanded="false"
                disabled
        >
          <i class="fa-solid fa-images"></i> Галереи
        </button>
      </div>
      <div class="card-body pt-2 pb-0 text-center">
        <button
                title="Просмотр галереи ваших таймлапсов"
                id="timelapseGallery"
                type="button"
                class="btn btn-success mb-2 d-none"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#imageGalleryModal"
        >
          <i class="fas fa-chart-pie"></i> Таймлапсы
        </button><br>
        <button
                title="Просмотр галереи ваших снимков"
                type="button"
                id="snapshotGallery"
                class="btn btn-warning text-dark mb-2 d-none"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#imageGalleryModal"
        >
          <i class="fas fa-dollar-sign"></i> Снимки
        </button><br>
        <button
                title="Просмотр галереи ваших миниатюр"
                type="button"
                id="thumbnailGallery"
                class="btn btn-info mb-2 d-none"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#imageGalleryModal"
        >
          <i class="fas fa-print"></i> Миниатюры
        </button>
        <h5 id="noGalleryLabel" class="d-none">Нет доступных галерей</h5>
      </div>

    </div>
  </div>
  <div id="dashboardInfo" class="col-sm-12 col-md-6 col-lg-2 col-xl-2 mb-2 mb-2">
    <div class="card text-white bg-dark h-100">
      <div class="card-header dashHeader p-0">
        <button
                type="button"
                class="btn btn-secondary d-block ml-1 mr-1 p-1"
                href="#"
                aria-expanded="false"
                disabled
        >
          <i class="fas fa-chart-bar"></i> Статистика
        </button>
      </div>
      <div class="card-body pt-2 pb-0 text-center">
        <button
                title="Просмотр статистики за выбранный период"
                type="button"
                class="btn btn-success mb-2"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#currentStatistics"
        >
          <i class="fas fa-chart-pie"></i> Состояние
        </button><br>
        <button
                title="Просмотр статистики за выбранный период"
                type="button"
                class="btn btn-warning text-dark mb-2"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#costsStatistics"
        >
          <i class="fas fa-dollar-sign"></i> Стоимость / Расход
        </button><br>
        <button
                title="Просмотр статистики за прошлые месяцы"
                type="button"
                class="btn btn-info mb-2"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#printerStatistics"
        >
          <i class="fas fa-print"></i> Принтер
        </button><br>
        <button
                title="Просмотр статистики за прошлые месяцы"
                type="button"
                class="btn btn-primary mb-2"
                href="#"
                aria-expanded="false"
                data-toggle="modal" data-target="#fileStatistics"
        >
          <i class="fas fa-file-code"></i> Файл
        </button>
      </div>

    </div>
  </div>
  <div id="dashboardInfo" class="col-sm-12 col-md-12 col-lg-8 col-xl-8 mb-2">
    <div class="card text-white bg-dark h-100">
      <div class="card-header dashHeader p-0">
        <button
                type="button"
                class="btn btn-secondary d-block ml-1 mr-1 p-1"
                href="#"
                aria-expanded="false"
                disabled
        >
          <i class="fas fa-filter"></i> Фильтры
        </button>


      </div>
      <div class="card-body pt-1 pb-0 text-center">
        <div class="row">
          <div class="col-md-4 col-lg-4">
            <div class="row">
              <div class="col-lg-12 bg-dark text-center" id="historyRange">
                <h5>Диапазон</h5><hr>
                <div class="input-group d-inline-flex">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="inputGroup-sizing-default">Диапазон дат</span>
                  </div>
                  <input id="historyDateRange"  class="form-control" aria-label="Default" aria-describedby="inputGroup-sizing-default">
                </div>
                <div class="input-group mt-1 d-inline-flex">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="sortHistoryTable">Сортировка по: </label>
                  </div>
                  <select class="custom-select" id="sortHistoryTable">
                    <option             value="startDateAsc"
                                        data-path=".start"
                                        data-order="desc"
                                        data-type="datetime">Дата начала (&uarr;)</option>
                    <option             value="startDateDesc"
                                        data-path=".start"
                                        data-order="asc"
                                        data-type="datetime">Дата начала (&darr;)</option>
                    <option             selected value="endDateAsc"
                                        data-path=".end"
                                        data-order="desc"
                                        data-type="datetime">Дата окончания (&uarr;)</option>
                    <option             value="endDateDesc"
                                        data-path=".end"
                                        data-order="asc"
                                        data-type="datetime">Дата окончания (&darr;)</option>
                    <option             value="durationAsc"
                                        data-path=".end"
                                        data-order="desc"
                                        data-type="datetime">Длительность (&uarr;)</option>
                    <option             value="durationDesc">Длительность (&darr;)</option>
                    <option             value="printNameAsc"
                                        data-path=".printer"
                                        data-order="asc"
                                        data-type="text">Имя принтера (&uarr;)</option>
                    <option             value="printNameDesc"
                                        data-path=".printer"
                                        data-order="desc"
                                        data-type="text">Имя принтера (&darr;)</option>
                    <option             value="fileNameAsc"
                                        data-path=".file"
                                        data-order="asc"
                                        data-type="text">Имя файла (&uarr;)</option>
                    <option             value="fileNameDesc"
                                        data-path=".file"
                                        data-order="desc"
                                        data-type="text">Имя файла (&darr;)</option>
                    <option             value="11"
                                        class="d-none"
                                        data-path=".cost"
                                        data-order="asc"
                                        data-type="number">Стоимость (&uarr;)</option>
                    <option             value="12"
                                        class="d-none"
                                        data-path=".cost"
                                        data-order="desc"
                                        data-type="number">Стоимость (&darr;)</option>
                    <option             value="13"
                                        class="d-none"
                                        data-path=".usage"
                                        data-order="asc"
                                        data-type="number">Расход (&uarr;)</option>
                    <option             value="14"
                                        class="d-none"
                                        data-path=".usage"
                                        data-order="desc"
                                        data-type="number">Расход (&darr;)</option>

                  </select>
                </div>
                <div class="input-group mt-1 d-inline-flex">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="inputGroupSelect01">Элементов на странице: </label>
                  </div>
                  <select id="historyItemsPerPage"  data-type="items-per-page" class="custom-select" id="inputGroupSelect01">
                    <option value="25" selected>25</option>
                    <option value="50">50</option>
                    <option value="75">75</option>
                    <option value="100">100</option>
                    <option value="<%= Number.MAX_SAFE_INTEGER %>">Все</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-8 col-lg-8">
            <div class="row">
              <div class="col-md-6 col-lg-4 bg-dark text-center" id="historyPrinterFilters">
                <h5>Принтер</h5><hr>
                <div class="input-group mb-1 d-inline-flex">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historyPrinterNames">Имена: </label>
                  </div>
                  <select class="custom-select" id="historyPrinterNames"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="fileNames"
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1 d-none">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historyPrinterGroups">Группы: </label>
                  </div>
                  <select class="custom-select" id="historyPrinterGroups"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="pathName"
                          disabled
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1 d-inline-flex">
                  <input id="historyPrinterSearch" type="text" class="form-control" aria-label="Username" aria-describedby="basic-addon1"
                         data-jplist-control="textbox-filter"
                         data-group="history"
                         data-name="historyPrinterSearch"
                         data-path=".file"
                         type="text"
                         value=""
                         placeholder="Поиск...">
                </div>
              </div>
              <div class="col-md-6 col-lg-4 bg-dark text-center" id="historyFileFilters">
                <h5>Файл</h5><hr>
                <div class="input-group mb-1 d-inline-flex">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historyFileNames">Имена: </label>
                  </div>
                  <select class="custom-select" id="historyFileNames"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="fileNames"
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1 d-inline-flex">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historyFilePaths">Пути: </label>
                  </div>
                  <select class="custom-select" id="historyFilePaths"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="pathName"
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1 d-inline-flex">
                  <input id="historyFileSearch" type="text" class="form-control" aria-label="Username" aria-describedby="basic-addon1"
                         data-jplist-control="textbox-filter"
                         data-group="history"
                         data-name="fileNameSearch"
                         data-path=".file"
                         type="text"
                         value=""
                         placeholder="Поиск...">
                </div>
              </div>
              <div class="col-md-6 col-lg-4 bg-dark text-center" id="historySpoolFilters">
                <h5>Катушка</h5><hr>
                <div class="input-group mb-1 d-none">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historySpoolManu">Производитель: </label>
                  </div>
                  <select class="custom-select" id="historySpoolManu"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="fileNames"
                          disabled
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1 d-none">
                  <div class="input-group-prepend">
                    <label class="input-group-text" for="historySpoolMat">Материал: </label>
                  </div>
                  <select class="custom-select" id="historySpoolMat"
                          data-jplist-control="select-filter"
                          data-group="history"
                          data-name="fileNames"
                          disabled
                  >
                    <option selected
                            href="#"
                            data-value="0"
                            data-path="default"
                    >Фильтр</option>

                  </select>
                </div>
                <div class="input-group mb-1">
                  <input id="historySpoolSearch" type="text" class="form-control" aria-label="Username" aria-describedby="basic-addon1"
                         data-jplist-control="textbox-filter"
                         data-group="history"
                         data-name="fileNameSearch"
                         data-path=".spool"
                         type="text"
                         value=""
                         placeholder="Поиск...">
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
<div class="card">
  <div class="row" id="historyPagination">

  </div>
</div>
<div class="row pb-0">
  <div class="col-lg-12 table-responsive-sm table-responsive-md">
    <table class="table-hover table table-dark text-center mb-0">
      <thead>
      <tr>
        <th class="table-dark" scope="col" width="350px">Статус</th>
        <th class="table-dark" scope="col">Итого время печати</th>
        <th class="table-dark" scope="col">Итого расход филамента</th>
        <th class="table-dark" scope="col">Итого стоимость филамента</th>
        <th class="table-dark" scope="col">Итого стоимость принтера</th>
        <th class="table-dark" scope="col">Общий итог</th>
        <th class="table-dark" scope="col">Средняя стоимость в час</th>
      </tr>
      </thead>
      <tbody id="historyTableTotals">
      <tr>
        <th class="table-dark" scope="col">
          <div class="progress mb-0">
            <div
                    id="totalSuccessPercent"
                    class="progress-bar progress-bar-striped bg-success"
                    role="progressbar"
                    style="width: 0%"
                    aria-valuenow="0%"
                    aria-valuemin="0"
                    aria-valuemax="100"
            >
            </div>
            <div
                    id="totalCancelledPercent"
                    class="progress-bar progress-bar-striped bg-warning"
                    role="progressbar"
                    style="width: 0%"
                    aria-valuenow="0%"
                    aria-valuemin="0"
                    aria-valuemax="100"
            >
              0%
            </div>
            <div
                    id="totalFailurePercent"
                    class="progress-bar progress-bar-striped bg-danger"
                    role="progressbar"
                    style="0"
                    aria-valuenow="0%"
                    aria-valuemin="0"
                    aria-valuemax="100"
            >
              0%
            </div>
          </div>
        </th>
        <th id="totalPrintTime" class="table-dark" scope="col"></th>
        <th id="totalFilament" class="table-dark" scope="col"></th>
        <th id="totalCost" class="table-dark" scope="col"></th>
        <th id="printerTotalCost" class="table-dark" scope="col"></th>
        <th id="combinedTotalCost" class="table-dark" scope="col"></th>
        <th id="averageCostPerHour" class="table-dark" scope="col"></th>
      </tr>
      </tbody>
    </table>
  </div>
</div>
<div class="row">
  <div id="wrapper" class="col-lg-12 table-responsive-sm table-responsive-md pt-0">
    <table id="historyTableTop" class="table table-dark text-center">
      <thead>
      <tr>
        <th class="table-dark sticky-table table-dark" scope="col">Состояние</th>
        <th class="table-dark sticky-table table-dark" scope="col">Принтер</th>
        <th class="table-dark sticky-table table-dark" scope="col">Пользователь</th>
        <th class="table-dark sticky-table table-dark" scope="col">Имя файла</th>
        <th class="table-dark sticky-table table-dark" scope="col">Дата начала</th>
        <th class="table-dark sticky-table table-dark" scope="col">Длительность</th>
        <th class="table-dark sticky-table table-dark" scope="col">Дата окончания</th>
        <th class="table-dark sticky-table table-dark" scope="col">Филамент</th>
        <th class="table-dark sticky-table table-dark" scope="col">Общая стоимость</th>
        <th class="table-dark sticky-table table-dark" scope="col">Стоимость в час</th>
        <th class="sticky-table table-dark" scope="col">Действия</th>
      </tr>
      </thead>
      <tbody id="historyTable">

      </tbody>

    </table>

  </div>
</div>
  <script src="/assets/js/history.runner.<%= clientVersion %>.min.js" type="module"></script>

  <div class="modal fade" id="currentStatistics" tabindex="0" role="dialog" aria-labelledby="historyModal" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h3 class="modal-title" id="historyModalLabel"><button type="button" class="btn btn-dark float-right d-block" href="#" aria-expanded="false" disabled="">
              Статистика состояний
            </button></h3>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span class="text-white" aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <div class="row">
            <div class="col-lg-6">
              <h6 class="d-inline-block">Процент успеха в день</h6> (<small id="dateRange-successRatePerDay"></small>)<hr>
              <div id="printCompletionByDay">

              </div>
            </div>
            <div class="col-lg-6">
              <h6 class="d-inline-block">Итого печати в день</h6> (<small id="dateRange-printTotalsPerDay"></small>)<hr>
              <div id="printCompletionOverTime"></div>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-6">
              <h6>Процент успеха в месяц</h6><hr>
              <div id="monthlySuccessRate"></div>
            </div>
            <div class="col-lg-6">
              <h6>Итого печати в месяц</h6><hr>
              <div id="monthlyPrintRate"></div>
            </div>
          </div>
        </div>


        <div class="modal-footer" id="historySave">
          <button type="button" class="btn btn-light" data-dismiss="modal">
            Закрыть
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="modal fade" id="costsStatistics" tabindex="0" role="dialog" aria-labelledby="historyModal" aria-hidden="true">
  <div class="modal-dialog modal-xl" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title" id="historyModalLabel"><button type="button" class="btn btn-dark float-right d-block" href="#" aria-expanded="false" disabled="">
            Статистика стоимости и расхода
          </button></h3>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span class="text-white" aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <h6 class="d-inline-block">Текущие итоги данных</h6> (<small id="dateRange-currentDataTotals"></small>)<hr>
        <div class="row">
          <div class="col-lg-2 text-center">
            <div class="row">
              <div class="col-lg-12">
                <h6>Итого по состояниям</h6><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Завершено
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">
              <b id="completedCount"><%= printStatistics.completed %></b>
            </span>
                </button><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Отменено
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
              <b id="cancelledCount"><%= printStatistics.cancelled %></b>
            </span>
                </button><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Ошибка
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
              <b id="failedCount"><%= printStatistics.failed %></b>
            </span>
                </button>
              </div>
            </div>
          </div>
          <div class="col-lg-10">
            <div class="row">
              <div class="col-lg-3 text-center">
                <h6>Итого</h6><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Время печати
                  <span id="totalPrintTime" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                      <%= helpers.generateTime(printStatistics.totalPrintTime) %>
                    </span>
                </button><hr>
                <button  type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Расход филамента
                  <span id="totalFilamentUsage" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">
                      <%= printStatistics.totalFilamentUsage %>
                    </span>
                </button><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Стоимость
                  <span id="totalCost" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info">
                      <%= (parseFloat(printStatistics.totalSpoolCost) + parseFloat(printStatistics.totalPrinterCost)).toFixed(2) %>
                    </span>
                </button>
              </div>
              <div class="col-lg-3 text-center">
                <h6>Наибольшие</h6><hr>
                <button type="button" class="btn btn-dark position-relative btn-sm" disabled>
                  Время печати
